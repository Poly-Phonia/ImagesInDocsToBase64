{
  "name": "imagesindocstobase64",
  "displayName": "Images In Docs To Base64",
  "description": "ドキュメント内で参照している画像ファイルパスをbase64に置き換えます。",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other","Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "imagesindocstobase64.convertMarkdownImages",
        "title": "Images In Docs To Base64:Markdownファイル内のローカル画像参照をbase64文字列に置き換える。"
      }
    ]
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Poly-Phonia/ImagesInDocsToBase64.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
